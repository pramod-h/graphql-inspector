{
  "name": "@pramod_sh/graphql-inspector",
  "version": "0.2.0",
  "description": "GraphQL static analysis CLI for React apps: detect overfetching, dead queries, dead fragments, duplicate documents, unused Code Generator types, query complexity, and schema drift across Apollo Client, urql, Relay, and graphql-request.",
  "keywords": [
    "graphql",
    "graphql-inspector",
    "overfetch",
    "overfetching",
    "static-analysis",
    "apollo",
    "apollo-client",
    "urql",
    "relay",
    "graphql-request",
    "graphql-code-generator",
    "codegen",
    "react",
    "nextjs",
    "cli",
    "dead-code",
    "dead-query",
    "unused-fields",
    "schema-drift",
    "graphql-cli"
  ],
  "license": "MIT",
  "author": "Pramod H",
  "homepage": "https://github.com/pramod-h/graphql-inspector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pramod-h/graphql-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/pramod-h/graphql-inspector/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "graphql-inspector": "dist/cli.js",
    "gqi": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "graphql": "^16.9.0",
    "ora": "^5.4.1",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
